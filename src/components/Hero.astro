---
// Hero.astro
import { Image } from 'astro:assets';
import profileImg from '../assets/profile1.jpg';
---
<section class="hero" id="sobre">
  <div class="hero-photo">
    <Image
      src={profileImg}
      alt="Pedro Cordeiro Lima"
      loading="eager"
      fetchpriority="high"
      class="hero-photo-img"
    />
  </div>
  <div class="hero-content">
    <p class="hero-label">Hortolândia, SP · Disponível para projetos</p>
    <h1>Pedro Cordeiro Lima</h1>
    <p class="hero-title">Desenvolvedor & Integrador de Sistemas</p>
    <p class="hero-sub">
      Trabalho com pequenas empresas para conectar sistemas, eliminar trabalho manual e construir presença digital — sem depender de uma área de TI interna.
    </p>
    <div class="hero-actions">
      <a href="#falar-projeto" class="btn-primary">Falar sobre seu projeto</a>
      <a href="#projetos" class="btn-outline">Ver projetos</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: calc(100svh - 85px); /* Adjusted to match height minus exact nav height */
    overflow: hidden;
  }

  .hero-photo {
    position: relative;
    overflow: hidden;
    background: #1a2a3a;
    height: 100%;
  }

  .hero-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px;
    border-left: 1px solid rgba(26, 25, 22, 0.08);
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-stone);
    margin-bottom: 24px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-obsidian);
    margin-bottom: 8px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    font-style: italic;
    color: var(--color-stone);
    margin-bottom: 40px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--color-stone);
    line-height: 1.7;
    margin-bottom: 48px;
    max-width: 380px;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-grove);
    color: var(--color-mint);
    padding: 14px 32px;
    font-size: 15px;
    font-family: var(--font-body);
    font-weight: 500;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-outline {
    display: inline-block;
    background: transparent;
    color: var(--color-obsidian);
    padding: 14px 32px;
    font-size: 15px;
    font-family: var(--font-body);
    font-weight: 500;
    border: 1.5px solid var(--color-obsidian);
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .btn-outline:hover {
    background: var(--color-obsidian);
    color: var(--color-ivory);
  }

  /* Tablet: 768px – 1024px */
  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      height: auto;
      min-height: 100svh;
    }
    .hero-content {
      padding: 48px 40px;
    }
    .hero h1 {
      font-size: 40px;
    }
    .hero-title {
      font-size: 17px;
    }
  }

  /* Mobile: até 767px */
  @media (max-width: 767px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: 55svh auto;
      height: auto;
      min-height: 100svh;
    }
    .hero-photo {
      height: 55svh;
    }
    .hero-photo-img {
      object-position: center 20%;
    }
    .hero-content {
      padding: 40px 24px 48px;
      border-left: none;
      border-top: 1px solid rgba(26, 25, 22, 0.08);
    }
    .hero h1 {
      font-size: 34px;
    }
    .hero-title {
      font-size: 16px;
      margin-bottom: 24px;
    }
    .hero-sub {
      font-size: 15px;
      margin-bottom: 36px;
      max-width: 100%;
    }
    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary,
    .btn-outline {
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }
  }
</style>
