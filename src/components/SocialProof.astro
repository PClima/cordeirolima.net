---
// SocialProof.astro
import { Image } from 'astro:assets';
import ibmLogo from '../assets/IBM_Logo.png';
import boschLogo from '../assets/Bosch_Logo.png';
import maxionLogo from '../assets/Maxion_Logo.png';
---
<section class="social-proof">
  <span class="sp-label">Experiência em</span>
  <div class="sp-divider"></div>
  <div class="sp-carousel">
    <div class="sp-track">
      <!-- 6 sets idênticos: a animação move exatamente 1/6 do track (1 set), criando loop perfeito -->
      <!-- Set 1 (acessível) -->
      <div class="sp-set">
        <span class="sp-logo"><Image src={ibmLogo} alt="IBM" width={140} height={56} quality={82} loading="eager" /></span>
        <span class="sp-logo"><Image src={boschLogo} alt="Bosch" width={56} height={56} quality={82} loading="eager" /></span>
        <span class="sp-logo"><Image src={maxionLogo} alt="Greenbrier Maxion" width={56} height={56} quality={82} loading="eager" /></span>
        <span class="sp-logo text-logo">Stako</span>
      </div>
      <!-- Sets 2–6 (decorativos) -->
      {[2, 3, 4, 5, 6].map(() => (
        <div class="sp-set" aria-hidden="true">
          <span class="sp-logo"><Image src={ibmLogo} alt="" width={140} height={56} quality={82} loading="eager" /></span>
          <span class="sp-logo"><Image src={boschLogo} alt="" width={56} height={56} quality={82} loading="eager" /></span>
          <span class="sp-logo"><Image src={maxionLogo} alt="" width={56} height={56} quality={82} loading="eager" /></span>
          <span class="sp-logo text-logo">Stako</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: 48px 0;
    border-top: 1px solid rgba(26, 25, 22, 0.08);
    border-bottom: 1px solid rgba(26, 25, 22, 0.08);
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--color-ivory);
    overflow: hidden;
  }

  .sp-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-stone);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 80px;
    margin-right: 8px;
  }

  .sp-divider {
    width: 1px;
    height: 20px;
    background: rgba(26, 25, 22, 0.15);
    flex-shrink: 0;
    margin-right: 8px;
  }

  .sp-carousel {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  /*
   * 6 sets × 464px/set = 2784px de track total.
   * -16.6667% = -464px = exatamente 1 set → loop sem salto.
   * Cobre telas até 2320px (2784 − 464) sem espaço vazio.
   */
  .sp-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: marquee 24s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-16.6667%); }
  }

  /* padding-right = mesmo valor do gap interno → cria "pitch" uniforme entre sets */
  .sp-set {
    display: flex;
    align-items: center;
    gap: 72px;
    padding-right: 72px;
  }

  .sp-logo {
    display: flex;
    align-items: center;
  }

  .sp-logo img {
    height: 28px;
    width: auto;
    opacity: 0.3;
    filter: grayscale(100%);
    display: block;
    transition: opacity 0.2s ease;
  }

  .sp-logo img:hover {
    opacity: 0.6;
  }

  .text-logo {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-stone);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .text-logo:hover {
    color: rgba(26, 25, 22, 0.65);
  }

  /* Tablet: 768px – 1024px */
  @media (max-width: 1024px) {
    .social-proof {
      padding: 40px 0;
    }
    .sp-label {
      margin-left: 40px;
    }
  }

  /* Mobile: até 767px */
  @media (max-width: 767px) {
    .social-proof {
      padding: 32px 0;
      flex-wrap: wrap;
      gap: 12px;
    }
    .sp-label {
      margin-left: 24px;
      margin-right: 0;
    }
    .sp-divider {
      display: none;
    }
    .sp-carousel {
      width: 100%;
      flex: none;
    }
    .sp-set {
      gap: 48px;
      padding-right: 48px;
    }
  }
</style>
